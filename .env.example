# ========================================
# AI 백엔드 모드 설정
# ========================================
# 'gpu'   - 자체 GPU PC 서버만 사용 (클라우드 API 불필요)
# 'cloud' - 클라우드 API만 사용 (Replicate + OpenAI)
# 'auto'  - GPU 서버 우선, 실패 시 클라우드 폴백 (기본값)
AI_BACKEND_MODE=auto

# ========================================
# 자체 GPU PC 서버 설정
# ========================================
# GPU 서버 URL (ComfyUI, Automatic1111, InvokeAI 등)
GPU_API_URL=http://localhost:7860
# GPU 서버 인증 키 (선택사항)
GPU_API_KEY=

# ========================================
# 클라우드 API (AI_BACKEND_MODE=cloud 또는 auto일 때 필요)
# ========================================
# Replicate API (인테리어 리모델링 폴백)
REPLICATE_API_TOKEN=your_replicate_api_token_here
# OpenAI API (사진 보정 폴백)
OPENAI_API_KEY=your_openai_api_key_here
